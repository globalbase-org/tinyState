sub reg_template_length
{
    my $aa = $_[0];
    $aa =~ s/\$\{([a-zA-Z0-9_]*)\}//g;
    return length($aa);
}

sub reg_template
{
    my $inp = $_[0];
    my @ary = ();
    foreach ( keys %$inp ) {
	my $kk = $_;
	if ( !($kk =~ m/\$\{([a-zA-Z0-9_]*)\}/) ) {
	    next;
	}
	push(@ary,$kk);
    }
    @ary = sort {reg_template_length($b) <=> reg_template_length($a) } @ary;
    my @template_ary = ();
    foreach ( @ary ) {
	my $aa = $_;
	my $dd = $inp->{$aa};
	$aa =~ s/^type\://;
	my $bb = $aa;
	$aa =~ s/\[/\\[/g;
	$aa =~ s/\]/\\]/g;
	$aa =~ s/\</\\</g;
	$aa =~ s/\>/\\>/g;
	$aa =~ s/\*/\\*/g;
	$aa =~ s/\$\{[a-zA-Z0-9_]+\}/(.*)/g;
	$dd->{templateExpression} = $aa;
	$dd->{templateOrg} = $bb;
	my @sp = split(/^$aa$/,$bb);
	$dd->{templateArgs} = \@sp;
	push(@template_ary,$dd);
    }
    foreach ( @ary ) {
	my $kk = $_;
	delete $inp->{$kk};
    }
    $inp->{'__templates'} = \@template_ary;
}


sub get_type_info
{
    my $inp = $_[0];
    my $type = $_[1];
    my $result = $inp->{"type:".$type};

    if ( $result ) {
	return $result;
    }
    foreach ( @{$inp->{'__templates'}} ) {
	my $tmp = $_;
	my $exp = $tmp->{templateExpression};
	if ( !($type =~ m/^$exp$/) ) {
	    next;
	}
	my $args = $tmp->{templateArgs};
	my $result = copy_body($tmp);
	my @sp = split(/^$exp$/,$type);
	my $i = 1;
	for ( ; $i <= $#$args ; $i ++ ) {
	    my $arg = $args->[$i];
	    $arg =~ s/^\$\{//;
	    $arg =~ s/\}$//;
	    $result->{"argument:".$arg} = $sp[$i];
	}
	$result->{type} = $type;
	$result->{name} = reg_name($type);
	$inp->{"type:".$type} = $result;
	if ( $result->{refer} ) {
	    get_type_info($inp,replace_arg($result->{refer},$result));
	}
	delete $result->{outputEnable};
       	return $result;
    }
    print STDERR "--- ".Dumper($inp);
    die "not match the type $type\n";

}



