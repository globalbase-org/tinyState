sub regulation_name
{
    my $inp = $_[0];
    $inp =~ s/[ \t\n\r]+/ /g;
    $inp =~ s/ ([\:,\.\;\[\]\<\>\*])/$1/g;
    $inp =~ s/([\:,\.\;\[\]\[\]\<\>\*]) /$1/g;
    $inp =~ s/^ //;
    $inp =~ s/ $//;
    return $inp;
}

sub copy_body
{
    my $inp = $_[0];
    if ( (ref $inp) eq "HASH" ) {
	my %ret = ();
	foreach ( keys %$inp ) {
	    my $key = $_;
	    $ret{$key} = copy_body($$inp{$key});
	}
	return \%ret;
    }
    elsif ( (ref $inp) eq "ARRAY" ) {
	my @ret = ();
	foreach ( @$inp ) {
	    my $dd = $_;
	    push(@ret,copy_body($dd));
	}
	return \@ret;
    }
    else {
	return $inp;
    }
}

sub regulation
{
    my $inp = $_[0];
    if ( (ref $inp) eq "HASH" ) {
	my %ret = ();
	foreach( keys %$inp ) {
	    my $key = $_;
	    my $reg = regulation_name($key);
	    my $body = regulation($$inp{$key});
	    if ( (($key) eq "inherit" || ($key eq "type")) && !(ref $body) ) {
		$body = regulation_name($body);
	    }
	    for ( ; $reg =~ s/\<([^\>]+),([^\>]+)\>/<$1++++$2>/ ; ) {}
	    for ( ; $reg =~ s/^([^\:]+)\:(.*),([^,]+)$/$1:$2/ ; ) {
		my $aa = $1;
		my $bb = $3;
		$bb =~ s/\+\+\+\+/,/g;
		my $res = $aa.":".$bb;
		$ret{$res} = copy_body($body);
	    }
	    $reg =~ s/\+\+\+\+/,/g;
	    $ret{$reg} = $body;
	}
	return \%ret;
    }
    elsif ( (ref $inp) eq "ARRAY" ) {
	my @ret = ();
	foreach ( @$inp ) {
	    my $dd = $_;
	    push(@ret,regulation($dd));
	}
	return \@ret;
    }
    else {
	return $inp;
    }
}


sub reg_path
{
    my $tp = $_[0];
    $tp =~ s/\-/_/g;
    $tp =~ s/\//_SS_/g;
    return $tp;
}

sub reg_name
{
    my $inp = $_[0];
    $inp =~ s/ /__/g;
    $inp =~ s/\*/_XX_/g;
    $inp =~ s/\[\]/_KK_/g;
    $inp =~ s/\</_LT_/g;
    $inp =~ s/\>/_GT_/g;
    $inp =~ s/,/_PP_/g;
    return $inp;
}

sub reg_name_list
{
    my $inp = $_[0];
    foreach ( keys %$inp ) {
	my $key = $_;
	if( !($key =~ m/^type\:(.*)$/) ) {
	    next;
	}
	my $org = $1;
	my $body = $$inp{$key};
	if ( (ref $body) ne "HASH" ) {
	    next;
	}
	if ( !$body->{name} ) {
	    $body->{name} = reg_name($org);
	}
	if ( !$body->{type} ) {
	    $body->{type} = regulation_name($org);
	}	    
    }
    return $inp;
}

sub reg_array
{
    my $inp = $_[0];
    if ( (ref $inp) eq "HASH" ) {
	my %ret = ();
	foreach ( keys %$inp ) {
	    my $kk = $_;
	    $ret{$kk} = reg_array($inp->{$kk});
	}
	return \%ret;
    }
    if ( (ref $inp) eq "ARRAY" ) {
	my $ret = "";
	foreach( @$inp ) {
	    my $line = $_;
	    $ret .= $line."\n";
	}
	return $ret;
    }
    return $inp;
}

sub setup_global
{
    my $inp = $_[0];
    $global_headerpost = $inp->{headerpost};
    $global_headerdir = $base_dir."/".$inp->{headerdir};
    $global_bodydir = $base_dir."/".$inp->{bodydir};
    $global_variable{"headerpost"} = $global_headerpost;
    $global_variable{"headerdir"} = $global_headerdir;
    $global_variable{"bodydir"} = $global_bodydir;
    unshift(@include_search_path,$global_headerdir);
    foreach ( keys %$inp ) {
	my $key = $_;
	if ( !($key =~ m/^global\:(.*)$/) ) {
	    next;
	}
	my $dd = $1;
	$global_variable{$dd} = $inp->{$key};
    }
}

sub get_header_filename
{
    my $inp = $_[0];
    foreach ( @include_search_path ) {
	my $path = $_;
	my $filename = $path."/".$inp;
	if ( -e $filename ) {
	    return $filename;
	}
    }
    return "";
}

my $getHeader_cache = {};


sub get_header_filename_include
{
    my $inp = $_[0];
    my @target = @include_search_path;
    my $ghc = $getHeader_cache;
    foreach ( @target ) {
	my $path = $_;
	my $filename = $path."/".$inp;
	if ( -e $filename ) {
	    return $inp;
	}
	my $dirok = "";
	if ( $ghc->{$path} ) {
	    $dirok = $ghc->{$path}->{$inp};
	}
	if ( !$dirok && -e $path ) {
	    open(INH,"find $path -name '*.h' -print|");
	    while(<INH>) {
		my $dir = $_;
		$dir =~ s/[\n\r]//g;
		if ( !($dir =~ m@/([^/]+)$@) ) {
		    next;
		}
		my $filename = $1;
		$ghc->{$path}->{$filename} = $dir;
		if ( $filename eq $inp ) {
		    $dirok = $dir;
		    last;
		}
	    }
	}
	if ( $dirok ) {
	    return substr($dirok,length($path)+1);
	}
    }
    return $global_headerpost."/".$inp;
}



sub get_load_filename
{
    my $inp = $_[0];
    if ( -e $inp ) {
	return $inp;
    }
    my $filename = $base_dir."/".$inp;
    if ( -e $filename ) {
	return $filename;
    }
    foreach ( @interface_path ) {
	my $b = $_;
	$filename = $b."/".$inp;

	if ( -e $filename ) {
	    return $filename;
	}
    }
    print "cannot find the file $inp\n";
    return "";
}

sub load_file 
{
    my $file = $_[0];
    print  STDERR "INCLUDE $file\n";
    if ( !open(IN,"<$file") ) {
	die "cannot open the file $file\n";
    }
    $loading_files{$file} = 1;
    my $code = "";
    while(<IN>) {
	my $line = $_;
	$code .= $line;
    }
    close(IN);
    my $data = eval($code);
    if ( !$data ) {
	die "parsing error !! $file\n";
    }
    $data = regulation($data);
    if ( $data->{include} ) {
	print STDERR "LOADING ".$data->{include}."...\n";
	my @inc_ary = split(/,/,$data->{include});
	foreach ( @inc_ary ) {
	    my $ff = $_;
	    my $inp = load_file(get_load_filename($ff));
	    foreach ( keys %$inp ) {
		my $key = $_;
		if ( $data->{$key} ) {
		    next;
		}
		$data->{$key} = $inp->{$key};
	    }
	}
	delete $data->{include};
    }
    if ( $file =~ m@^$base_dir@ ) {
	return $data;
    }
    foreach ( keys %$data ) {
	my $key = $_;
	if ( $key =~ m/^type\:/ ) {
	    $data->{$key}->{"outputEnable"} = "off";
	}
    }
    return $data;
}

