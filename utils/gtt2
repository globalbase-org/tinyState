    if ( $body->{$ee_flag} ) {
	my $eef = $body->{$ee_flag};
	my $eeff = 0;
	if ( $body->{$ee_flag} eq "IGNORE" ) {
	    return "";
	}
	if ( $eef =~ m/^\>\>(.*)$/ ) {
	    $eef = $1;
	    $eeff = 1;
	}
	if ( $eeff && $decode_type eq "static" ) {
	    return "";
	}
	if ( $member ) {
	    if ( $body->{$ee_flag} =~ m/\;$/ ) {
		return "   ".replace_member($eef,$member,$body,2)."\n";
	    }
	    return "   ".replace_member($eef,$member,$body,2).";\n";
	}
	else {
	    if ( $body->{$ee_flag} =~ m/\;$/ ) {
		return "   ".replace_simple($eef,"_src","(*dest)",
					    {'body' => $body,'argument:property' => $body->{property}})."\n";
	    }
	    return "   ".replace_simple($eef,"_src","(*dest)",
					{'body' => $body,'argument:property' => $body->{property}}).";\n";
	}
    }
    elsif ( $body->{activeMember} ) {
	my $ret = '
   gtData * src;
';
	my @rr = ();
	my %path_hash = ();
	foreach ( keys %$body ) {
	    my $key = $_;
	    if ( !($key =~ m/^member\:(.*)$/) ) {
		next;
	    }
	    my $name = $1;
	    if ( $body->{$key} eq "IGNORE" ) {
		next;
	    }
	    if ( ($path eq "") && ($body->{$key}->{path}) ) {
		if ( $decode_type ne "virtual" ) {
		    next;
		}
		if ( $ee_flag ne "import" ) {
		    next;
		}
		if ( $path_hash{$body->{$key}->{path}} ) {
		    next;
		}
		$path_hash{$body->{$key}->{path}} = 1;
		push(@rr,
		     "   ".reg_path($body->{$key}->{path})."->gtt_import(_src->get(\"".
		     $body->{$key}->{path}."\"));"."\n");
		next;
	    }
	    elsif ( ($path ne "") && ($path ne $body->{$key}->{path}) ) {
		next;
	    }
	    my @pp = gen_property_get($name,$path,$key,$body);
#	    my $decc = gen_decode($body->{$key},$path,$decode_type,$ee_flag,$name);
	    my $decc = gen_decode($body->{$key},$path,"virtual",$ee_flag,$name);
	    if ( $decc ) {
		push(@rr,$pp[1].
		     "   if ( src ) {\n".
		     $decc.
		     "   }\n".
		     "   else {\n".
		     gen_destroy($body->{$key},$path,"destroy",$name).
		     "   }\n");
	    }
	}
	return $ret.join("",sort @rr);
    }
    else {
	if ( $member ) {
	    if ( $ee_flag eq "decode" ) {
		return replace_member("   gtt_".reg_name($body->{type}).'::decode(base,&$dest,$src);'."\n",$member,$body,2);
	    }
	    else {
		return replace_member("   gtt_".reg_name($body->{type}).'::gtt_import(base,&$dest,$src);'."\n",$member,$body->{ary},2);
	    }
	}
	else {
	    return "   stdObject::panic(\"undefined $ee_flag instance!!\");\n";
	}
    }
}

