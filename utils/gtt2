    if ( !$ts ) {
	return "";
    }
    if ( !($ts =~ m/^(.*)\:(.*)$/) ) {
	die "invalid typeSpace ($ts)";
    }
    my $typeSpace = $1;
    my $typeNameList = $2;
    my @tnl = split /[ \t]*,[ \t]*/,$typeNameList;
    my $first = "";
    foreach ( @tnl ) {
	my $tn = $_;
	my $f = gen_typeSpace__($body,$className,$typeSpace,$tn);
	if ( !$first ) {
	    $first = $f;
	}
    }
    return $first;
}

sub gen_typeSpace__
{
    my $body = $_[0];
    my $className = $_[1];
    my $typeSpace = $_[2];
    my $typeName = $_[3];
    my $dd;
    $dd = $typeName."[".$className."]";

    if ( $global_typeSpace{$typeSpace} ) {
	my $ee = $global_typeSpace{$typeSpace};
	my $d = $dd;
	$d =~ s/\[/\\[/g;
	$d =~ s/\]/\\]/g;
	$ee = ",".$ee.",";
	if ( !($ee =~ m/,$d,/) ) {
	    $global_typeSpace{$typeSpace} .= ",".$dd;
	}
	if ( $body->{outputEnable} ne "off" ) {
	    $global_typeSpace{$typeSpace} =~ s/^\:off\://;
	}
    }
    else {
	if ( $body->{outputEnable} eq "off" ) {
	    $global_typeSpace{$typeSpace} = ":off:".$dd;
	}
	else {
	    $global_typeSpace{$typeSpace} = $dd;
	}
    }
    return 'type("'.$typeName.'");';
}

sub gen_sub_gtt
{
    my $body = $_[0];
    my $path = $_[1];
    my $func = $_[2];
    my $header = $_[3];
    my $headerpost = $_[4];
    if ( !$body->{activeMember} ) {
	return "";
    }
    if ( $path ne "" ) {
	return "";
    }
    my @rr = ();
    my %path_hash = ();
    foreach ( keys %$body ) {
	my $key = $_;
	if ( !($key =~ m/^member\:(.*)$/) ) {
	    next;
	}
	my $name = $1;
	my $path = $body->{$key}->{path};
	if ( !$path ) {
	    next;
	}
	if ( $path_hash{$path} ) {
	    next;
	}
	$path_hash{$path} = 1;
	push(@rr,&$func($name,$body,$path,$header,$headerpost));
    }
    return join("",sort @rr);
}

