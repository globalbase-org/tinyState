sub gen_include_inc
{
    my $body = $_[0];
    my $include_path = "";
    if ( $body->{define} ) {
	$include_path = '#include "'.replace_simple($body->{define},"","",$body).'"'."\n";
    }
    if ( $body->{include} ) {
	my $inc = $body->{include};
	if ( $inc =~ m/\=\>/ ) {
	    my $res = "";
	    $inc .= "=>";
	    for ( ; $inc =~ s/^([^\=]+)\=\>// ; ) {
		my $el = $1;
		    $res = replace_simple($el,"","",$body);
		my $path = get_header_filename_include($res);
		if ( $path ) {
		    $include_path .= '#include "'.$res.'"'."\n";
		    last;
		}
	    }
	    if ( $inc eq "" ) {
		$include_path .= '#include "'.$res.'"'."\n";
	    }
	}
	else {
	    $inc .= ",";
	    for ( ; $inc =~ s/^([^,]+),// ; ) {
		my $el = $1;
		if ( $el =~ m/^\<(.*)\>$/ ) {
		    $include_path .= '#include <'.replace_simple($1,"","",$body).'>'."\n";
		}
		else {
		    $include_path .= '#include "'.replace_simple($el,"","",$body).'"'."\n";
		}
	    }
	}
    }
    return $include_path;
}

sub gen_include
{
    my $body = $_[0];
    my $path = $_[1];
    my $headerpost = $_[2];
    if ( $body->{activeMember} ) {
	my @rr = ();
	my %include_hash = ();
	foreach ( keys %$body ) {
	    my $key = $_;
	    if ( !($key =~ m/^member\:(.*)$/) ) {
		next;
	    }
	    my $name = $1;
	    if ( $body->{$key} eq "IGNORE" ) {
		next;
	    }
	    if ( ($path eq "") && ($body->{$key}->{path}) || 
		 ($path ne "") && ($path ne $body->{$key}->{path}) ) {
		next;
	    }
	    if ( $body->{$key}->{type} =~ m/^gtt\_/ ) {
		if ( $body->{$key}->{type} =~ m/\[\]/ ) {
		    next;
		}
		my $tp = $body->{$key}->{type};
		$tp =~ s/\*$//g;
		my $hf = get_header_filename_include(reg_name($tp).'.h');
		my $res = '#include "'.$hf."\"\n";
		if ( !$include_hash{$res} ) {
		    push(@rr,$res);
		    $include_hash{$res} = 1;
		}
		next;
	    }

	    my $res = gen_include($body->{$key},$path,$headerpost);
	    if ( $include_hash{$res} ) {
		next;
	    }
	    $include_hash{$res} = 1;
	    push(@rr,$res);
	}
	return join("",sort @rr);
    }
    my $res = "";
    if ( $body->{type} && !($body->{type} =~ m/\[\]/) ) {
	$res = '#include "'.get_header_filename_include('gtt_'.reg_name($body->{type}).'.h')."\"\n";
    }
    if ( $body->{inherit} && !($body->{inherit} =~ m/\[\]/) ) {
	$res = '#include "'.get_header_filename_include('gtt_'.reg_name($body->{inherit}).'.h')."\"\n";
    }
#    if ( $body->{"type:".$body->{type}} ) {
#	$res .= gen_include($body->{"type:".$body->{type}},$path,$headerpost);
#    }
#    if ( $body->{"type:".$body->{inherit}} ) {
#	$res .= gen_include($body->{"type:".$body->{inherit}},$path,$headerpost);
#    }
    if ( $body->{include} && !($body->{include} =~ m/\[\]/) ) {
	$res .= gen_include_inc($body);
    }
    return $res;
}


