sub gen_helper
{
    my $line = $_[0];
    my $type = $_[1];
    my $class;
    my $launch;
    if ( !$line ) {
	return "";
    }
    if ( $line =~ m/NEW[ \t]+([a-zA-Z0-9_]+)/ ) {
	$class = $1;
	$launch = "";
    }
    elsif ( $line =~ m/NEW[ \t]*\(([a-zA-Z0-9_]+)\)[\n\r \t]*([a-zA-Z0-9_]+)/ ) {
	$class = $1;
	$launch = $2;
	$line =~ s/NEW[ \t]*\([a-zA-Z0-9_]+\)[\n\r \t]*/NEW /;
    }
    else {
	die "invalid helper definition $type $line\n";
    }
    if ( $type eq "dec" ) {
	return "   $class *& helper;";
    }
    elsif ( $type eq "init" ) {
	return ",helper(($class*&)TS_BASECLASS::helper)";
    }
    elsif ( ($type eq "new") && !$launch ) {
	return '   REF_SET(helper,('.$line.'));
    invoke_listen(NEW stdEvent(TSE_UPDATED,
			      ifThis,
			      helper));
    ';
    }
    elsif ( ($type eq "new") && $launch ) {
	return "   ".$line.";\n".
	    '   return INI_HELPER_LAUNCH_WAIT;
}
TS_STATE(INI_HELPER_LAUNCH_WAIT)
{
    if ( ev->type != TSE_RETURN )
	return 0;
    REF_SET(helper,dynamic_cast<'.$class.'*>(ev->msg_obj));
    invoke_listen(NEW stdEvent(TSE_UPDATED,
			      ifThis,
			      helper));
';
    }
    elsif ( $type eq "detach-wait" ) {
	return "if ( helper && helper->detach() == 0 ) return 0;"
    }
    elsif ( $type eq "fin" ) {
	return "   REF_SET(helper,0);";
    }
}

sub gen_typeSpace
{
    my $body = $_[0];
