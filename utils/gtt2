sub read_define_single
{
    my $result = $_[0];
    my $name = $_[1];
    my %ret = ();
    for ( ; $result =~ s/^(.*?)\;// ; ) {
	my $line = regulation_name($1);
	my ($type,$ptr,$var,$ary1);
	my @ary = ();
	if ( $line =~ m/^typedef ([a-zA-Z0-9_]+)(\<[^\>]+\>|)(\*+)$name(\[[^\]]+\])*/ ) {
	    $type = $1.$2;
	    $ptr = $3;
	    $ary1 = $4;
	}
	elsif ( $line =~ m/^typedef ([a-zA-Z0-9_]+)(\<[^\>]+\>| )$name(\[[^\]]+\])*/ ) {
	    $type = $1.$2;
	    $ptr = "";
	    $ary1 = $3;
	}
	else {
	    next;
	}
	my $alist = "";
	if ( $#ary < 0 ) {
	    for ( ; $ary1 =~ s/\[([^\]]+)\]// ; ) {
		my $sizeLength = $1;
		push(@ary,$sizeLength);
		$alist .= "[]";
	    }
	}
	$ret{type} = {
	    inherit => regulation_name($type.$ptr.$alist),
	};
	if ( $#ary >= 0 ) {
	    $ret{type}->{ary} = \@ary;
	}
	return \%ret;
    }
    return \%ret;
}

sub read_define
{
    my $inp = $_[0];
    my $name = $_[1];
    my $headerdir = $_[2];
    my $fpath = get_header_filename($inp);
    if ( !$fpath || !open(IN,"<$fpath") ) {
	if ( !open(IN,"<$fpath") ) {
	    die "cannot open the file $inp\n";
	}
	else {
	    $loading_files{$inp} = 1;
	}
    }
    else {
	$loading_files{$fpath} = 1;
    }

    my $data = "";
    while(<IN>) {
	my $line = $_;
	$line =~ s/[\r\n]+//g;
	$line =~ s/\/\/(.*)$//;
	if ( $line =~ m/^[ \t]*\#/ ) {
	    next;
	}
	$data .= $line;
    }
    close(IN);
    my %ret = ();

    $data =~ s/\/\*(.*?)\*\///g;
    if ( !($data =~ m/typedef[ \t]+struct[ \t]+[a-zA-Z0-9_]+[ \t]*\{([^\}]*)\}[ \t]*$name[ \t]*\;/) ) {
	my $ret = read_define_single($data,$name);
	if ( !$ret->{type} ) {
	    die "undefined type $name in the file $inp ($data)\n";
	}
        return $ret;
    }
    my $result = $1;
    for ( ; $result =~ s/^(.*?)\;// ; ) {
	my $line = regulation_name($1);
	my ($type,$ptr,$var,$ary1);
	my @ary = ();
	if ( $line =~ m/^unsigned ([a-zA-Z0-9_]+)\:([0-9]+)/ ) {
	    $type = "unsigned";
	    $ptr = "";
	    $var = $1;
	    $ary1 = "";
	}
	elsif ( $line =~ m/^struct ([a-zA-Z0-9_]+)(\*+)([a-zA-Z0-9_]+)(\[[^\]]+\])*/ ) {
	    $type = "struct ".$1;
	    $ptr = $2;
	    $var = $3;
	    $ary1 = $4;
	}
	elsif ( $line =~ m/^struct ([a-zA-Z0-9_]+) ([a-zA-Z0-9_]+)(\[[^\]]+\])*/ ) {
	    $type = "struct ".$1;
	    $ptr = "";
	    $var = $2;
	    $ary1 = $3;
	}
	elsif ( $line =~ m/^([a-zA-Z0-9_]+)(\<[^\>]+\>|)(\*+)([a-zA-Z0-9_]+)(\[[^\]]+\])*/ ) {
	    $type = $1.$2;
	    $ptr = $3;
	    $var = $4;
	    $ary1 = $5;
	}
	elsif ( $line =~ m/^([a-zA-Z0-9_]+)(\<[^\>]+\>| )([a-zA-Z0-9_]+)(\[[^\]]+\])*/ ) {
	    $type = $1.$2;
	    $ptr = "";
	    $var = $3;
	    $ary1 = $4;
	}
	else {
	    next;
	}
	my $alist = "";
	if ( $#ary < 0 ) {
	    for ( ; $ary1 =~ s/\[([^\]]+)\]// ; ) {
		my $sizeLength = $1;
		push(@ary,$sizeLength);
		$alist .= "[]";
	    }
	}
	$ret{"member:".$var} = {
	    type => regulation_name($type.$ptr.$alist),
	};
	if ( $#ary >= 0 ) {
	    $ret{"member:".$var}->{ary} = \@ary;
	}
    }
    return \%ret;
}

sub reg_define
{
    my $inp = $_[0];
    foreach ( keys %$inp ) {
	my $key = $_;
	my $body = $$inp{$key};
	if ( !($key =~ m/type\:(.*)/) ) {
	    next;
	}
	if ( (ref $body) ne "HASH" ) {
	    next;
	}
	if ( !$body->{define} ) {
	    next;
	}
	my $defineList = read_define($body->{define},$body->{name},$inp->{headerdir});
	if ( $defineList->{type} ) {
	    my $dd = $defineList->{type};
	    if ( $#{$dd->{ary}} >= 0 ) {
		$body->{ary} = $dd->{ary};
	    }
	    inherit_key($body,$dd,"inherit");
	}
	else {
	    foreach ( keys %$defineList ) {
		my $rkey = $_;
		my $dd = $defineList->{$rkey};
		if ( $body->{$rkey} ) {
		    $body->{$rkey}->{type} = $dd->{type};
		    if ( $#{$dd->{ary}} >= 0 ) {
			$body->{$rkey}->{ary} = $dd->{ary};
		    }
		    inherit_key($body,$dd,"inherit");
		    next;
		}
		$body->{$rkey} = $defineList->{$rkey};
	    }
	}
    }
    return $inp;
}


sub inherit_argument
{
    my $inbody = $_[0];
    my $typeBody = $_[1];
    foreach ( keys %$typeBody ) {
	my $kk = $_;
	if ( !($kk =~ m/^argument\:/) ) {
	    next;
	}
	if ( $inbody->{$kk} ) {
	    next;
	}
	$inbody->{$kk} = copy_body($typeBody->{$kk});
    }
}

sub inherit_key
{
    my $inbody = $_[0];
    my $typeBody = $_[1];
    my $key = $_[2];
    if ( $inbody->{$key} ) {
	return;
    }
    if ( !$typeBody->{$key} ) {
	return;
    }
    $inbody->{$key} = copy_body($typeBody->{$key});
}

sub inherit_key_all
{
    my $inbody = $_[0];
    my $typeBody = $_[1];
    foreach ( keys %$typeBody ) {
	my $kk = $_;
	if ( $kk eq "outputEnable" ) {
	    next;
	}
	if ( $inbody->{$kk} ) {
	    next;
	}
	$inbody->{$kk} = copy_body($typeBody->{$kk});
    }
}

sub inherit_other_key
{
    my $body = $_[0];
    my $to = $_[1];
    my $from = $_[2];
    if ( $body->{$to} ) {
	return;
    }
    if ( !$body->{$from} ) {
	return;
    }
    $body->{$to} = $body->{$from};
}


sub reg_member_handle
{
    my $inp = $_[0];
    my $key = $_[1];
    my $body = $_[2];
    if ( $body->{handle} eq "complete" ) {
	return;
    }
    elsif ( $body->{handle} eq "deal" ) {
	die "loop reference $key\n";
    }
    $body->{handle} = "deal";
    if ( $body->{inherit} ) {
	my $type = regulation_name($body->{inherit});
	my $typeBody;
	$typeBody = get_type_info($inp,$type);
	if ( !$typeBody ) {
	    die "undefined type(1) $type\n";
	}
	reg_member_handle($inp,"type:".$type,$typeBody);
	inherit_key_all($body,$typeBody);
    }
    foreach ( keys %$body ) {
	my $inkey = $_;
	if ( !($inkey =~ m/^member\:/) ) {
	    next;
	}
	my $inbody = $body->{$inkey};
	my $type = $inbody->{type};
	if ( !$type ) {
	    next;
	}
	$body->{activeMember} ++;
	my $typeBody;
	$typeBody = get_type_info($inp,$type);
	if ( !$typeBody ) {
	    die "undefined type(2) $type\n";
	}
	reg_member_handle($inp,"type:".$type,$typeBody);
	inherit_key($inbody,$typeBody,"initial");
	inherit_key($inbody,$typeBody,"updated");
	inherit_key($inbody,$typeBody,"ary");
	inherit_key($inbody,$typeBody,"compare");
	inherit_key($inbody,$typeBody,"copy");
	inherit_key($inbody,$typeBody,"encode");
	inherit_key($inbody,$typeBody,"decode");
	inherit_key($inbody,$typeBody,"import");
	inherit_key($inbody,$typeBody,"export");
	inherit_key($inbody,$typeBody,"destroy");
	inherit_key($inbody,$typeBody,"include");
	inherit_key($inbody,$typeBody,"dynamicPath");
	inherit_key($inbody,$typeBody,"typeSpace");
	inherit_argument($inbody,$typeBody);
    }
    $body->{handle} = "complete";
}

sub reg_member
{
    my $inp = $_[0];
    foreach ( keys %$inp ) {
	my $key = $_;
	if ( !($key =~ m/^type\:/) ) {
	    next;
	}
	my $body = $inp->{$key};
	reg_member_handle($inp,$key,$body);
    }
    return $inp;
}

sub dec_var_ptr_org
{
    my $name = $_[0];
    my $body = $_[1];
    my $type = $body->{type};
    my $ret;
    if ( $type =~ s/[\[\]]+//g ) {
	$ret = $type."(*".$name.")";
    }
    else {
	$ret = $type."*".$name;
    }
    $type = $body->{type};
    $type =~ s/^(.*)(\[(.*))$/$2/;
    my $i = 0;
    for ( ; $type =~ s/\[\]// ; ) {
	$ret .= "[".$body->{ary}->[$i]."]";
    }
    for ( ; $type =~ s/\[\]// ; ) {
	$ret .= "[]";
    }
    return $ret;
}

sub dec_var_org
{
    my $name = $_[0];
    my $body = $_[1];
    my $ret = $body->{type};
    $ret =~ s/[\[\]]+//g;
    $ret .= " ".$name;
    my $type = $body->{type};
    $type =~ s/^(.*)(\[(.*))$/$2/;
    my $i = 0;
    for ( ; $type =~ s/\[\]// ; ) {
	$ret .= "[".$body->{ary}->[$i]."]";
    }
    for ( ; $type =~ s/\[\]// ; ) {
	$ret .= "[]";
    }
    return $ret;
}

