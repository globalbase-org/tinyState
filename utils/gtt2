sub diff_updated
{

    my $dir = $_[0];
    $dir = $base_dir."/".$dir;
    open(IN,"ls -a1 $dir|");
    my %new_list = ();
    my %old_list = ();
    while(<IN>) {
	my $line = $_;
	$line =~ s/[\n\r]//g;
	if ( $line eq "." ) {
	    next;
	}
	if ( $line eq ".." ) {
	    next;
	}
	if ( !($line =~ m/(\.h|\.cpp)$/) ) {
	    next;
	}
	if ( $line =~ m/^\./ ) {
	    $new_list{substr($line,1)} = 1;
	}
	else {
	    $old_list{$line} = 1;
	}
    }
    close(IN);
    foreach ( keys %old_list ) {
	my $file = $_;
	if ( $new_list{$file} ) {
	    next;
	}
	system("rm -rf $dir/$file");
    }
    foreach ( keys %new_list ) {
	my $file = $_;
	if ( $old_list{$file} ) {
	    open(IN,"diff $dir/.$file $dir/$file|");
	    my $data = "";
	    while(<IN>) {
		$data .= $_;
	    }
	    close(IN);
	    if ( $data ) {
		system("mv -f $dir/.$file $dir/$file");
	    }
	    else {
		system("rm -rf $dir/.$file");
	    }
	}
	else {
	    system("mv -f $dir/.$file $dir/$file");
	}
    }
}


