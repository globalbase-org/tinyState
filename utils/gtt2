sub replace_arg_loop
{
    my $inp = $_[0];
    my $body = $_[1];

    foreach ( keys %$body ) {
	my $arg = $_;
	if ( !($arg =~ m/^argument\:(.*)/) ) {
	    next;
	}
	my $var = $1;
	my $value = $body->{$arg};
	my $value2 = reg_name($value);
	$inp =~ s/\$$var/$value/g;
	$inp =~ s/\$\%$var/$value2/g;
    }

    if ( $body->{body} ) {
	$inp = replace_arg_loop($inp,$body->{body});
    }
    return $inp;
}

sub replace_global
{
    my $inp = $_[0];
    foreach ( keys %global_variable ) {
	my $kk = $_;
	my $dd = $global_variable{$kk};
	$inp =~ s/\$\{$kk\}/$dd/g;
	$inp =~ s/\$$kk/$dd/g;
    }
    return $inp;
}

sub replace_arg
{
    my $inp = $_[0];
    my $body = $_[1];
    $inp = replace_arg_loop($inp,$body);
    $inp = replace_global($inp);
    $inp =~ s/\$bodydir/$global_bodydir/g;
    $inp =~ s/\$headerdir/$global_headerdir/g;
    $inp =~ s/\$headerpost/$global_headerpost/g;
    return $inp;
}

sub replace_member
{
    my $inp = $_[0];
    my $mb = $_[1];
    my $body = $_[2];
    my $only_src = $_[3];
    if ( !$mb ) {
	$inp =~ s/\$dest/(*dest)/g;
	$inp =~ s/\$src/(*src)/g;
	my $val = $body->{type};
	$val =~ s/\*$//;
	$inp =~ s/\$gttType/$val/g;
	my $i = 1;
	my $ary = $body->{ary};
	foreach ( @$ary ) {
	    my $ss = $_;
	    $inp =~ s/\$size$i/$ss/g;
	}
	$inp = replace_arg($inp,$body);
	return $inp;
    }
    if ( (ref $inp) eq "ARRAY" ) {
	$inp = join("\n",@$inp);
    }
    if ( $only_src == 1 ) {
	$inp =~ s/\$src/src->$mb/g;
	$inp =~ s/\$dest/dest/g;
    }
    elsif ( $only_src == 2 ) {
	$inp =~ s/\$src/src/g;
	$inp =~ s/\$dest/dest->$mb/g;
    }
    else {
	$inp =~ s/\$src/src->$mb/g;
	$inp =~ s/\$dest/dest->$mb/g;
    }
    my $val = $body->{type};
    $val =~ s/\*$//;
    $inp =~ s/\$gttType/$val/g;
    $val = get_property2($mb,$body->{property});
    $inp =~ s/\$property/$val/g;
    my $i = 1;
    my $ary = $body->{ary};
    foreach ( @$ary ) {
	my $ss = $_;
	$inp =~ s/\$size$i/$ss/g;
    }
    $inp = replace_arg($inp,$body);
    return $inp;
}

sub replace_simple
{
    my $inp = $_[0];
    my $src = $_[1];
    my $dest = $_[2];
    my $body = $_[3];
    $inp =~ s/\$src/$src/g;
    $inp =~ s/\$dest/$dest/g;
    if ( $body ) {
	$inp = replace_arg($inp,$body);
    }
    return $inp;
}

