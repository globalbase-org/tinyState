sub gen_encode
{
    my $body = $_[0];
    my $path = $_[1];
    my $encode_type = $_[2];
    my $ee_flag = $_[3];
    my $member = $_[4];

    inherit_other_key($body,"import","decode");
    inherit_other_key($body,"export","encode");

    if ( $body->{$ee_flag} ) {
	if ( $body->{$ee_flag} eq "IGNORE" ) {
	    return "";
	}
	if ( $member ) {
	    if ( $body->{$ee_flag} =~ m/\;$/ ) {
		return "   ".replace_member($body->{$ee_flag},$member,$body,1)."\n";
	    }
	    return "   ".replace_member($body->{$ee_flag},$member,$body,1).";\n";
	}
	else {
	    my $dec = '   gtData * ret = 0,* ret1 = 0;'."\n";
	    my $out = replace_simple($body->{$ee_flag},'$src',"ret",$body);
	    my $out = replace_member($out,$member,$body,1);
	    if ( $body->{$ee_flag} =~ m/\;$/ ) {
		return $dec."   ".$out."\n";
	    }
	    return $dec."   ".$out.";\n";
	}
    }
    elsif ( $body->{activeMember} ) {
	my @rr = ();
	my @ret_type = ();
	my %path_hash = ();
	foreach ( keys %$body ) {
	    my $key = $_;
	    if ( $key =~ m/^member\:(.*)$/ ) {
		my $name = $1;
		if ( $body->{$key} eq "IGNORE" ) {
		    next;
		}
		if ( ($path eq "") && ($body->{$key}->{path}) ) {
		    if ( $encode_type ne "virtual" ) {
			next;
		    }
		    if ( $ee_flag ne "export" ) {
			next;
		    }
		    if ( $path_hash{$body->{$key}->{path}} ) {
			next;
		    }
		    $path_hash{$body->{$key}->{path}} = 1;
		    my @ps = gen_property_set($name,$path,$key,$body);
		    push(@rr,
			 "   ret->set(\"".$body->{$key}->{path}."\",".
			 reg_path($body->{$key}->{path})."->gtt_export());\n");
		    $ret_type[1] = 1;
		    next;
		}
		elsif ( ($path ne "") && ($path ne $body->{$key}->{path}) ) {
		    next;
		}
		my @ps = gen_property_set($name,$path,$key,$body);
		my $enc = gen_encode($body->{$key},$path,$encode_type,$ee_flag,$name);
		if ( $enc ) {
		    push(@rr,$enc.$ps[1]);
		}
		$ret_type[$ps[0]] = 1;
	    }
	    elsif ( $key =~ m/^property\:(.*)/ ) {
		my $prop = $1;
		if ( $body->{$key} eq "IGNORE" ) {
		    next;
		}
		if ( $body->{$key}->{$ee_flag} eq "IGNORE" ) {
		    next;
		}
		if ( !$body->{$key}->{property} ) {
		    $body->{$key}->{property} = $prop;
		}
		if ( ($path eq "") && ($body->{$key}->{path}) || 
		     ($path ne "") && ($path ne $body->{$key}->{path}) ) {
		    next;
		}
		$ret_type[1] = 1;
		push(@rr,'   ret->set("'.get_property("",$body->{$key}).'",'.get_value($body->{$key}->{value},$encode_type).');'."\n");
	    }
	}
	my $ret = '
   gtDataHash * ret = 0;
   gtData * ret1 = 0;
';
	if ( $ret_type[1] == 1 ) {
	    $ret .= '
   ret = NEW gtDataHash();
';
	}
	return $ret.join("",sort @rr);
    }
	
    else {
	if ( $member ) {
	    if ( $ee_flag eq "encode" ) {
		return replace_member('   $dest = gtt_'.reg_name($body->{type}).'::encode(base,&$src);'."\n",$member,$body,1);
	    }
	    else {
		return replace_member('   $dest = gtt_'.reg_name($body->{type}).'::gtt_export(base,&$src);'."\n",$member,$body,1);
	    }
	}
	else {
	    return "stdObject::panic(\"undefined $ee_flag instance!!\");\n";
	}
    }
}

