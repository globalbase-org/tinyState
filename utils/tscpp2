sub get_tmp
{
    my $filename = $_[0];
    if ( $filename =~ m/(.*)\/([^\/]+)$/ ) {
	my $dir = $1;
	my $fn = $2;
	return "$dir/.$fn";
    }
    else {
	return ".".$filename;
    }
}

sub copy_tmp
{
    my $from = $_[0];
    my $to = $_[1];

    if ( !(-e $to) ) {
	system("mv $from $to");
	return;
    }

    open(IN,"<$from");
    my $from_data = "";
    while(<IN>) {
	$from_data .= $_;
    }
    close(IN);

    open(IN,"<$to");
    my $to_data = "";
    while(<IN>) {
	$to_data .= $_;
    }
    if ( $from_data eq $to_data ) {
	system("rm $from");
	return;
    }
    system("rm $to");
    system("mv $from $to");
}


sub elem_text
{
    my $e = $_[0];
    return ref($e) eq 'HASH' ? $e->{text} : $e;
}

sub get_filenames
{
    my $filename = $_[0];
    my $trunc;
    if ( $opt_header eq "" ) {
	$filename =~ m/^(.*)\.c$/;
	$trunc = $1;
    }
    else {
	if ( $filename =~ m/\// ) {
	    $filename =~ m/\/([^\/]*)(\.cpp|\.cp|\.cxx)$/;
	    $trunc = $opt_baseheader."/".$opt_header."/c++/".$1;
	}
	else {
	    $filename =~ m/^(.*)(\.cpp|\.cp|\.cxx)$/;
	    $trunc = $opt_baseheader."/".$opt_header."/c++/".$1;
	}
	system("mkdir -p $opt_baseheader/$opt_header/c++");
    }
    return {
	"opened" => $trunc."_.h",
	"public" => $trunc."_pb.h"
    }
}


