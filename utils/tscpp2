	if ( !$in_block && $line =~ m|/\*\*| ) {
	    @pending = ($line);
	    $in_block = 1 unless $line =~ m|\*/|;
	    next;
	}
	if ( $in_block ) {
	    push(@pending, $line);
	    if ( $line =~ m|\*/| ) { $in_block = 0; }
	    next;
	}
	if ( $line =~ m|^\s*///| ) {
	    push(@pending, $line);
	    next;
	}
	if ( $line =~ m|^\s*$| ) { next; }
	if ( $line =~ m!class[ \t]+(TS_THISCLASS|TS_INTERFACE|[A-Za-z0-9_]+)[ \t]*[:{]! ) {
	    $class_comment = [@pending] if @pending;
	    @pending = ();
	    next;
	}
	if ( $line =~ m|IMP_PRIVATE| ) { @pending = (); next; }
	if ( @pending && $line =~ m|([A-Za-z0-9_~]+)[ \t]*\(| ) {
	    my $fname = $1;
	    $fname =~ s/_$//;
	    push @{$func_comments{$fname}}, [@pending] if $fname ne "";
	    @pending = ();
	    next;
	}
	if ( $line =~ m|\S| ) { @pending = (); }
    }
    return { class_comment => $class_comment, func_comments => \%func_comments };
}

sub insert_field
{
    my $classname = $_[0];
    my $place = $_[1];
    my $inserted = $_[2];
    my $list = $_[3];
    my $field = "public";
    my $result = {
	"public" => [],
	"protected" => [],
	"private" => []
    };
    my @result_pre = ();
    my @result_post = ();
    for ( ; ; ) {
	if ( $#$list < 0 ) {
	    @$list = @result_pre;
	    return;
	}
	my $elem = shift(@$list);
	my $line = elem_text($elem);
	push(@result_pre,$elem);
	if ( $line =~ m/class[ \t]+$classname[ \t]*\:/ ) {
	    last;
	}
	if ( $line =~ m/class[ \t]+TS_THISCLASS[ \t]*\:/ ) {
	    last;
	}
	if ( $line =~ m/class[ \t]+TS_INTERFACE[ \t]*\:/ ) {
	    last;
	}
    }
    # Track brace depth so inline method bodies with }; don't terminate the parse
    my $depth = 1;  # class opening { is on the class definition line (in @result_pre)
    for ( ; $#$list >= 0 ; ) {
	my $elem = shift(@$list);
	my $line = elem_text($elem);
	my $opens  = () = $line =~ /\{/g;
	my $closes = () = $line =~ /\}/g;
	$depth += $opens - $closes;
	if ( $depth <= 0 ) {
	    push(@result_post,$elem);
	    last;
	}
	if ( $depth == 1 ) {
	    if ( $line =~ m/^\s*public\s*:/ ) {
		$field = "public";
		next;
	    }
	    elsif ( $line =~ m/^\s*protected\s*:/ ) {
		$field = "protected";
		next;
	    }
	    elsif ( $line =~ m/^\s*private\s*:/ ) {
		$field = "private";
		next;
	    }
	}
	push(@{$result->{$field}},$elem);
    }
    push(@result_post,@$list);
    if ( ref($inserted) eq 'ARRAY' ) {
        foreach my $ins_line (@{$inserted}) {
            push(@{$result->{$place}},$ins_line);
        }
    } else {
        push(@{$result->{$place}},"\t".$inserted);
    }
    @$list = @result_pre;
    if ( $#{$result->{private}} >= 0 ) {
	push(@$list,"private:",@{$result->{private}});
    }
    if ( $#{$result->{protected}} >= 0 ) {
	push(@$list,"protected:",@{$result->{protected}});
    }
    if ( $#{$result->{public}} >= 0 ) {
	push(@$list,"public:",@{$result->{public}});
    }
    push(@$list,@result_post);
}


sub replace_macro
{
    my $classname = $_[0];
    my $baseclassname = $_[1];
    my $list = $_[2];
    my $imp_classname = $classname."_";
    my $imp_baseclassname = $baseclassname."_";
    my @result;
    foreach ( @$list ) {
	my $elem = $_;
	if ( ref($elem) eq 'HASH' ) {
	    my %new_elem = %$elem;
	    $new_elem{text} =~ s/TS_INTERFACE/$classname/g;
	    $new_elem{text} =~ s/TS_BASEINTERFACE/$baseclassname/g;
	    $new_elem{text} =~ s/TS_THISCLASS/$imp_classname/g;
	    $new_elem{text} =~ s/TS_BASECLASS/$imp_baseclassname/g;
	    push(@result,\%new_elem);
	} else {
	    my $line = $elem;
	    $line =~ s/TS_INTERFACE/$classname/g;
	    $line =~ s/TS_BASEINTERFACE/$baseclassname/g;
	    $line =~ s/TS_THISCLASS/$imp_classname/g;
	    $line =~ s/TS_BASECLASS/$imp_baseclassname/g;
	    push(@result,$line);
	}
    }
    return @result;
}

sub scan_file
{
    my $filename = $_[0];
    my $filenames = get_filenames($filename);

    my $classname = "";
    my $baseclassname = "";
    my @states = ();
    my %thrStates = ();
    my @private_var = ();
    my %private_var_hash = ();
    my @protected_var = ();
    my @ref_var = ();
    my @implement_include = ();
    my @interface_include = ();
    my $this_header_prefix = "ts2/c++";
    my $base_header_prefix = "ts2/c++";
    my %state_comments = ();
    my $pending_state_comment = [];
    my $in_state_doc_block = 0;
    my $in_block_comment = 0;

    open(IN,"<$filename");
    while(<IN>) {
	my $line = $_;
	$line =~ s/[\n\r]//g;
	# Blank out C string/char literals before any comment-delimiter detection,
	# so that "/*", "*/" or "//" appearing INSIDE a literal (e.g. a token-set
	# string like "...%/*-+...") is not mistaken for a real comment. Detection
	# below uses $code; comment-body accumulation still uses the raw $line.
	(my $code = $line) =~ s/"(?:\\.|[^"\\])*"//g;   # remove "..."
	$code =~ s/'(?:\\.|[^'\\])*'//g;                  # remove '...'
	# Skip lines inside /* */ block comments (fix Problem B)
	if ( $in_block_comment ) {
	    if ( $line =~ m|\*/| ) { $in_block_comment = 0; }
	    next;
	}
	# Accumulate Doxygen /** */ comments outside TS_BEGIN_* blocks for state docs
	if ( !$in_state_doc_block && $code =~ m|/\*\*| ) {
	    $pending_state_comment = [$line];
	    $in_state_doc_block = 1 unless $code =~ m|\*/|;
	    next;
	}
	if ( $in_state_doc_block ) {
	    push(@$pending_state_comment, $line);
	    if ( $line =~ m|\*/| ) { $in_state_doc_block = 0; }
	    next;
	}
	if ( $line =~ m|^\s*///| ) {
	    push(@$pending_state_comment, $line);
	    next;
	}
	# Skip // comment lines (fix Problem B)
	if ( $code =~ m|^\s*//| ) {
	    $pending_state_comment = [];
	    next;
	}
	# Start tracking non-doc /* */ block comments (fix Problem B)
	if ( $code =~ m|/\*| && $code !~ m|\*/| ) {
	    $in_block_comment = 1;
	    $pending_state_comment = [];
	    next;
	}
	# Strip remaining inline /* */ for TS_STATE/TS_THREAD detection (fix Problem B)
	(my $stripped = $code) =~ s|/\*.*?\*/||g;
	if ( $stripped =~ m/CLASS_TINYSTATE\(([^\)\,]*),([^\)\,]*)\)/ ) {
	    $pending_state_comment = [];
	    $classname = $1;
	    $baseclassname = $2;
	    if ( $classname =~ m/^(.*)\/([^\/]+)$/ ) {
		$this_header_prefix = $1;
		$classname = $2;
	    }
	    if ( $baseclassname =~ m/^(.*)\/([^\/]+)$/ ) {
		$base_header_prefix = $1;
		$baseclassname = $2;
	    }
	}
	elsif ( $line =~ m/TS_BEGIN_IMPLEMENT/ ) {
	    $pending_state_comment = [];
	    while(<IN>) {
		my $line = $_;
		my $lineno = $.;
		$line =~ s/[\n\r]//g;
		if ( $line =~ m/TS_END_IMPLEMENT/ ) {
		    last;
		}
		elsif ( $line =~ m/\[\[\#\#REPEAT/ ) {
		    my $repeat;
		    while(<IN>) {
			my $ll = $_;
			$ll =~ s/[\n\r]//g;
			if ( $ll =~ m/\#\#\]\]/ ) {
			    last;
			}
			$repeat .= $ll."++CR++";
		    }
		    my $ii = 0;
		    my @repList;
		    for ( ; $repeat =~ s/\[\[([^\]\[]+)\]\]/++REP$ii++/ ; 
			$ii ++ ) {
			my $rep = $1;
			my @rep = split(/,/,$rep);
			$repList[$ii] = \@rep;
		    }
		    my $ii = 0;
		    my $result = "";
		    for ( ; ; $ii ++ ) {
			my $pic = $repeat;
			my $jj;
			for ( $jj = 0 ; $jj <= $#repList; $jj ++ ) {
			    my $repl = $repList[$jj]->[$ii];
			    if ( !$repl ) {
				last;
			    }
			    $pic =~ s/\+\+REP$jj\+\+/$repl/;
			}
			if ( $jj <= $#repList ) {
			    last;
			}
			$result .= $pic;
		    }
		    $result =~ s/\+\+CR\+\+$//;
		    my @rr = split(/\+\+CR\+\+/,$result);
		    push(@implement_include,@rr);  # REPEAT 展開行は行番号なし
		    next;
		}
		push(@implement_include,{text => $line, lineno => $lineno, file => $filename});
	    }
	}
	elsif ( $line =~ m/TS_BEGIN_INTERFACE/ ) {
	    $pending_state_comment = [];
	    while(<IN>) {
		my $line = $_;
		my $lineno = $.;
		$line =~ s/[\n\r]//g;
		if ( $line =~ m/TS_END_INTERFACE/ ) {
		    last;
		}
		push(@interface_include,{text => $line, lineno => $lineno, file => $filename});
	    }
	}
	elsif ( $stripped =~ m/TS_STATE\(([^\)\,]*)\)/ ) {
	    my $ss = $1;
	    push(@states,$ss);
	    $state_comments{$ss} = [@$pending_state_comment] if @$pending_state_comment;
	    $pending_state_comment = [];
	}
	elsif ( $stripped =~ m/TS_THREAD\(([^\)\,]*)\)/ ) {
	    my $ss = $1;
	    push(@states,$ss);
	    $thrStates{$ss} = 1;
	    $state_comments{$ss} = [@$pending_state_comment] if @$pending_state_comment;
	    $pending_state_comment = [];
	}
	elsif ( $line =~ m/TS_PRIVATE\((.*)/ ) {
	    $pending_state_comment = [];
	    my $ss = $1;
	    $ss =~ s/\)[ \t]*$//;
	    if ( !$private_var_hash{$ss} ) {
		push(@private_var,$ss);
		$private_var_hash{$ss} = 1;
	    }
	}
	elsif ( $line =~ m/TS_PROTECTED\((.*)/ ) {
	    $pending_state_comment = [];
	    my $ss = $1;
	    $ss =~ s/\)[ \t]*$//;
	    push(@protected_var,$ss);
	}
	elsif ( $line =~ m/TS_REF\(([^\)\,]*)\)/ ) {
	    $pending_state_comment = [];
	    my $ss = $1;
	    push(@ref_var,$ss);
	}
	elsif ( $line =~ m|\S| ) {
	    $pending_state_comment = [];
	}
    }
    if ( $classname eq "" ) {
	return;
    }
    my $inc;
    my $functions = scan_implement($classname."_",\@implement_include);
    my $doc_info = scan_doc_comments(\@implement_include);

    # Auto-detect class definition in interface block; append if absent
    {
	my $has_class_def = 0;
	foreach my $iline (@interface_include) {
	    if ( elem_text($iline) =~ m/class[ \t]+(${classname}|TS_INTERFACE)[ \t]*[:\{]/ ) {
		$has_class_def = 1;
		last;
	    }
	}
	if ( !$has_class_def ) {
	    if ( @{$doc_info->{class_comment}} ) {
		push(@interface_include, @{$doc_info->{class_comment}});
	    }
	    if ( $baseclassname ) {
		push(@interface_include,(
		    "class ".$classname." : public ".$baseclassname." {",
		    "};"
		    ));
	    }
	    else {
		push(@interface_include,(
		    "class ".$classname." : public stdObject {",
		    "};"
		    ));
	    }
	}
    }

    # Compute constructor arg names for TS_DEFARGS expansion
    my %argsName = ();
    foreach my $ff (@{$functions->{functions}}) {
	my $fn = $ff->{fname};
	if ( $ff->{type} eq "" ) { $fn =~ s/_$//; }
	next if $classname ne $fn;
	foreach my $aa (@{$ff->{args}}) {
	    my $str = $aa->{str};
	    $str =~ s/\=(.*)$//;
	    $str =~ s/[ \t]*$//;
	    $str =~ m/.*?([A-Za-z0-9_]+)$/;
	    my $v = $1;
	    next if $v eq "parent";
	    $argsName{$v} = $str;
	}
    }

    # Replace TS_DEFARGS in implement block with actual member declarations
    {
	my @new_impl = ();
	foreach my $elem (@implement_include) {
	    if ( elem_text($elem) =~ m/^\s*TS_DEFARGS\s*$/ ) {
		foreach my $v (keys %argsName) {
		    push(@new_impl, "\t".$argsName{$v}.";");  # 自動生成行、行番号なし
		}
	    } else {
		push(@new_impl, $elem);  # hashref のまま保存
	    }
	}
	@implement_include = @new_impl;
    }

    # Build content arrays for direct injection into class bodies
    my @if_public = ("\t".$classname."(int dummy,sPtr<tinyState_>);");
    my %fname_idx = ();
    foreach my $ff (@{$functions->{functions}}) {
	my $fname = $ff->{fname};
	if ( $ff->{type} eq "" ) { $fname =~ s/_$//; }
	my $idx = $fname_idx{$fname} // 0;
	$fname_idx{$fname} = $idx + 1;
	if ( defined($doc_info->{func_comments}{$fname}) &&
	     defined($doc_info->{func_comments}{$fname}[$idx]) ) {
	    push(@if_public, @{$doc_info->{func_comments}{$fname}[$idx]});
	}
	my $decl = "\t".$ff->{type}." ".$fname."(";
	for my $i (0..$#{$ff->{args}}) {
	    $decl .= $ff->{args}[$i]{str};
	    $decl .= "," if $i < $#{$ff->{args}};
	}
	$decl .= ");";
	push(@if_public, $decl);
    }
    foreach my $vv (@{$functions->{vars}}) {
	my $fname = $vv->{fname};
	my $type = $vv->{type};
	if ( $type =~ s/\[(.*)\]$// ) {
	    my $num = $1;
	    push(@if_public, "\t".$type."(& ".$fname.")[$num];");
	} elsif ( $type =~ m/&[ \t]*$/ ) {
	    push(@if_public, "\t".$type." ".$fname.";");
	} else {
	    push(@if_public, "\t".$type."& ".$fname.";");
	}
    }
    push(@if_public, "\tvirtual TS_REFER * getRefer();");
    push(@if_public, "\tvirtual const char * getClass();");
    push(@if_public, "\tvirtual const char * getClass(const char *);");

    my @if_protected = ("\tsPtr<".$classname."_> impl;");

    my @private_ts = ();
    foreach my $ss (@private_var) {
	push(@private_ts, "\t".$ss.";");
    }
    foreach my $ss (@states) {
	push(@private_ts, "\tinline TS_STATE_TYPE TS_FORCEINLINE _state_$ss(sPtr<stdEvent>);");
    }

    my @protected_ts = ();
    foreach my $ss (@protected_var) {
	push(@protected_ts, "\t".$ss.";");
    }
    foreach my $ss (@states) {
	if ( defined($state_comments{$ss}) && @{$state_comments{$ss}} ) {
	    foreach my $cline (@{$state_comments{$ss}}) {
		push(@protected_ts, "\t".$cline);
	    }
	}
	push(@protected_ts, "\tstatic TS_TRANS trans_$ss;");
	push(@protected_ts, "\tvirtual inline TS_STATE_TYPE TS_FORCEINLINE get_$ss() {");
	push(@protected_ts, "\t\treturn (TS_STATE_TYPE)&trans_$ss;");
	push(@protected_ts, "\t};");
    }
    push(@protected_ts, "");
    foreach my $ss (@states) {
	push(@protected_ts, "\tstatic TS_STATE_TYPE state_$ss(sPtr<tinyState_>,sPtr<stdEvent>);");
    }

    my @public_ts = (
	"\tstatic TS_REFER ts_refer;",
	"\tvirtual TS_REFER * getRefer() {",
	"\t\treturn &ts_refer;",
	"\t}",
	"\tstatic const char * className;",
	"\tvirtual const char * getClass() {",
	"\t\treturn className;",
	"\t}",
	"\tvirtual const char * getClass(const char * cls) {",
	"\t\tif ( strcmp(cls,className) == 0 )",
	"\t\t\treturn className;",
	($baseclassname
	    ? "\t\treturn this->".$baseclassname."_::getClass(cls);"
	    : "\t\treturn 0;"),
	"\t}",
	"\tsWptr<".$classname."> ifp;",
    );

    insert_field($classname."_",
		 "protected",\@protected_ts,\@implement_include);
    insert_field($classname."_",
		 "private",\@private_ts,\@implement_include);
    insert_field($classname."_",
		 "public",\@public_ts,\@implement_include);

    insert_field($classname,
		 "public",\@if_public,\@interface_include);
    insert_field($classname,
		 "protected",\@if_protected,\@interface_include);
    @implement_include = replace_macro($classname,$baseclassname,
				       \@implement_include);
    @interface_include = replace_macro($classname,$baseclassname,
				       \@interface_include);

    my $result = {
	"classname" => $classname,
	"baseclassname" => $baseclassname,
	"states" => \@states,
	"thrStates" => \%thrStates,
	"private_var" => \@private_var,
	"protected_var" => \@protected_var,
	"ref" => \@ref_var,
	"functions" => $functions->{functions},
	"vars" => $functions->{vars},
	"implement" => \@implement_include,
	"interface" => \@interface_include,
	"this_header_prefix" => $this_header_prefix,
	"base_header_prefix" => $base_header_prefix
	    
    };

    output_opened($filenames->{opened},$result);
    output_public($filenames->{public},$result);
}

