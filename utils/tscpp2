CLASS_TINYSTATE(+++HEADER+++/+++CLASS+++,+++REPBASECLASS+++)


#if 0

TS_BEGIN_IMPLEMENT


class TS_THISCLASS : public TS_BASECLASS {
public:
	+++CLASS+++_(
		sPtr<+++PARENTCLASS+++> parent);
	+++PARENTDECL+++
private:
protected:
	TS_DEFARGS
};

TS_END_IMPLEMENT

TS_BEGIN_INTERFACE
#include	"ts2/c++/sRptr.h"
class +++PARENTCLASS+++;
TS_END_INTERFACE

#endif


+++CLASS+++_::+++CLASS+++_(TS_ARGS0)
        : +++NAMEBASECLASS+++_(parent)+++PARENTINITIALIZE+++
{
    TS_CPARGS0
}



/*******************************************
	INSTANCE FUNCTIONS
********************************************/



/*******************************************
	STATE MACHINE
********************************************/



';


my $htemplate = '
#ifndef ___+++CLASS+++_cpp_H___
#define ___+++CLASS+++_cpp_H___

#include	"+++GHEADER+++/+++CLASS+++_pb.h"

#endif

';

sub new_template
{
    my $class = $_[0];
    my $header_ofs = $_[1];
    my $baseClass = $_[2];
    my $parentClass = $_[3];
    my $baseClassName;
    my $parentClassPath = "ts2/c++";
    my $parentGen = "";
print STDERR "---- $parentClass\n";
    if ( !$baseClass ) {
	$baseClass = "ts2/c++/tinyState";
	$baseClassName = "tinyState";
    }
    else {
	$baseClass =~ m/\/([^\/]+)$/;
	$baseClassName = $1;
    }
    if ( !$parentClass ) {
	$parentClass = "tinyState";
    }
    elsif ( $parentClass eq "-" ) {
	$parentClass = $baseClassName;
	$baseClass =~ m/^(.*)\/([^\/]+)$/;
	$parentClassPath = $1;
	if ( $parentClass ne "tinyState" ) {
	    $parentGen = "GEN";
	}
    }
    else {
	$parentClassPath = $parentClass;
	$parentClass =~ m/^(.*)\/([^\/]+)$/;
	$parentClass = $2;
	$parentGen = "GEN";
    }
    my $path = $ENV{PWD};
    my $rc = "";
    $class = $path."/".$class;
    if ( $class =~ s/^(.*)\/([^\/]+)$/$2/ ) {
	$path = $1;
    }
    my $rc_path = $path;
    print STDERR "NEW template $class -- $path\n";
    for ( ; ; ) {
	$rc = $rc_path."/.tscpp.rc";
	if ( -e $rc ) {
	    last;
	}
	if ( $rc_path =~ s/\/[^\/]+$// ) {
	    next;
	}
	$rc = "";
	last;
    }
    print STDERR "RC $rc $rc_path\n";
    if ( $rc eq "" ) {
	die "cannot found RC file .tscpp.rc";
    }
    my $rc_data = "";
    open(IN,"<$rc") or die "cannot open $rc";
    while(<IN>) {
	my $inp = $_;
	$rc_data .= $inp;
    }
    close(IN);
    $rc_data = eval($rc_data);
    my $hdr = $rc_data->{base};
    my $ghdr = $rc_data->{generated};
    my $data = $ctemplate;
    my $parentInit = "";
    my $parentInclude = "";
    my $parentDecl = "";
    if ( $parentGen ) {
	$parentDecl = "\n\tsRptr<".$parentClass.",tinyState>\t\tparent;";
	$parentInit = ",\n\t  parent(tinyState_::parent)";
	$parentInclude = "#include\t\"".$parentClassPath.".h\"\n";
    }
    $data =~ s/\+\+\+CLASS\+\+\+/$class/g;
    $data =~ s/\+\+\+HEADER\+\+\+/$header_ofs/g;
    $data =~ s/\+\+\+GHEADER\+\+\+/$ghdr/g;
    $data =~ s/\+\+\+REPBASECLASS\+\+\+/$baseClass/g;
    $data =~ s/\+\+\+NAMEBASECLASS\+\+\+/$baseClassName/g;
    $data =~ s/\+\+\+PARENTCLASS\+\+\+/$parentClass/g;
    $data =~ s/\+\+\+PARENTDECL\+\+\+/$parentDecl/g;
    $data =~ s/\+\+\+PARENTINITIALIZE\+\+\+/$parentInit/g;
    $data =~ s/\+\+\+PARENTINCLUDE\+\+\+/$parentInclude/g;
    open(OUT,">$path/$class.cpp") or die "cannot open $path/$class.cpp";
    print OUT $data;
    close(OUT);

    my $data = $htemplate;
    $data =~ s/\+\+\+CLASS\+\+\+/$class/g;
    $data =~ s/\+\+\+HEADER\+\+\+/$hdr/g;
    $data =~ s/\+\+\+GHEADER\+\+\+/$ghdr/g;
    $data =~ s/\+\+\+REPBASECLASS\+\+\+/$baseClass/g;
    $data =~ s/\+\+\+NAMEBASECLASS\+\+\+/$baseClassName/g;
    $data =~ s/\+\+\+PARENTCLASS\+\+\+/$parentClass/g;
    $data =~ s/\+\+\+PARENTINCLUDE\+\+\+/$parentInclude/g;
    open(OUT,">$rc_path/$hdr/$header_ofs/$class.h")
	or die "cannot open $rc_path/$hdr/$header_ofs/$class.h";
    print OUT $data;
    close(OUT);
}

