if ( $cmd eq "file" ) {
    scan_file($ARGV[1]);
}
elsif ( $cmd eq "new" ) {
    new_template($ARGV[1],$ARGV[2],$ARGV[3],$ARGV[4]);
}
else {
    print STDERR "invalid command $cmd\n";
    print STDERR '
tscpp.pl file <filename.cpp> [--header=<PATH1>][--baseheader=<PATH2>]

  generating tinyState framework interface and implement header file

  PATH1 path to directory of header files
  PATH2 relative path from PATH1 to generated header files

tscpp.pl new <PATH3/classname> <PATH4> [--header=<PATH1>][--baseheader=<PATH2>]
tscpp.pl new <PATH3/classname> <PATH4> [<PATH5/baseclass> [<PATH6/PARENT>]] [--header=<PATH1>][--baseheader=<PATH2>]

  generating template file of cpp and header file.
  PATH3 directory of cpp file and classname
  PATH4 headerfile directory
  PATH5/baseclass base class name and its directory. default is ts2/c++/tinyState
  PATH6/PARENT parent class name and its directory. default is ts2/c++/tinyState. if PARENT = '."'-'".' then same as base class.
';
}
exit(0);
