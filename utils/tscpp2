sub scan_implement
{
    my $classname = $_[0];
    my $argsptr = $_[1];
    my @args = @$argsptr;
    for ( ; $#args >= 0 ; ) {
	my $line = elem_text(shift(@args));
	$line =~ s/[\n\r]//g;
	if ( $line =~ m/class[ \t]+$classname[ \t]*\:/ ) {
	    last;
	}
	if ( $line =~ m/class[ \t]+TS_THISCLASS[ \t]*\:/ ) {
	    last;
	}
    }
    for ( ; $#args >= 0 ; ) {
	my $line = elem_text(shift(@args));
	$line =~ s/[\n\r]//g;
	if ( $line =~ m/public:/ ) {
	    last;
	}
    }
    my $pdata = "";
    my $in_pdata_block = 0;
    for ( ; $#args >= 0 ; ) {
	my $line = elem_text(shift(@args));
	$line =~ s/[\n\r]//g;
	if ( $line =~ m/^[ \t]*\/\// ) {
	    next;
	}
	if ( $in_pdata_block ) {
	    if ( $line =~ m|\*/| ) { $in_pdata_block = 0; }
	    next;
	}
	# Strip same-line /* */ comments and // tail comments (fix Problem A)
	$line =~ s|/\*.*?\*/||g;
	$line =~ s|//.*$||;
	# If a multi-line block comment starts, keep content before /* and track
	if ( $line =~ m|/\*| ) {
	    $line =~ s|/\*.*$||;
	    $in_pdata_block = 1;
	}
	if ( $line =~ m/\:/ ) {
	    last;
	}
	if ( $line =~ m/\}[ \t]*\;/ ) {
	    last;
	}
	# Replace inline method bodies {} (only after closing )) with ; — preserves = {} defaults (fix Problem C)
	1 while $line =~ s/\)[^\(\){}]*\{[^{}]*\}/);/g;
	$pdata .= $line." ";
    }
    my @funcs = split(/\;/,$pdata);
    my @func_list = ();
    my @var_list = ();
    foreach ( @funcs ) {
	my $item = $_;
	my $type = "";
	my $fname = "";
	my $args = "";
	my $vf = 0;
	$item =~ s/^[ \t]*//;
	if ( $item =~ m/^[ \t]*IMP_PRIVATE/ ) {
	    next;
	}
	if ( $item =~ m/^(\~[a-zA-Z0-9_]+)[ \t]*\((.*)\)/ ) {
	    $type = "";
	    $fname = $1;
	    $args = $2;
	}
	elsif ( $item =~ m/^(.*[^a-zA-Z0-9_])([a-zA-Z0-9_]+)[ \t]*\((.*)\)/ ) {
	    $type = $1;
	    $fname = $2;
	    $args = $3;
	}
	elsif ( $item =~ m/^([a-zA-Z0-9_]+)[ \t]*\((.*)\)/ ) {
	    $type = "";
	    $fname = $1;
	    $args = $2;
	}
	elsif ( $item =~ m/^(.*[^a-zA-Z0-9_])([a-zA-Z0-9_]+)[ \t]*\[(.*)\]$/ ) {
	    $type = $1."[".$3."]";
	    $fname = $2;
	    $args = "";
	    $vf = 1;
	}
	elsif ( $item =~ m/^(.*[^a-zA-Z0-9_])([a-zA-Z0-9_]+)[ \t]*$/ ) {
	    $type = $1;
	    $fname = $2;
	    $args = "";
	    $vf = 1;
	}
	else {
	    next;
	}
	if ( $fname eq "refDestroy" ) {
	    next;
	}
	if ( $fname eq "ifp" ) {
	    next;
	}
	my @argss = split(/,/,$args);
	my $num = 1;
	my @args_list = ();
	my $varg = "";
	foreach ( @argss ) {
	    my $aa = $_;
	    my $name;
	    if ( $aa =~ m/([a-zA-Z0-9_]+)\s*\=(.*)$/ ) {
		$name = $1;
	    }
	    elsif ( $aa =~ m/([a-zA-Z0-9_]+)$/ ) {
		$name = $1;
	    }
	    elsif ( $aa =~ m/\.\.\./ ) {
		$name = "";
		$varg = "varg";
	    }
	    else {
		$name = "__arg".$num;
		$num ++;
		$aa .= $name
	    }
	    $aa =~ s/^[ \t]+//;
	    $aa =~ s/[ \t]+$//;
	    push(@args_list,{
		str => $aa,
		var => $name});
	}
	$type =~ s/[ \t]+$//;
	if ( $vf == 0 ) {
	    push(@func_list,{
		type => $type,
		fname => $fname,
		args => \@args_list,
		varg => $varg
		 });
	}
	else {
	    push(@var_list,{
		type => $type,
		fname => $fname,
		 });
	}
    }
    return {
	functions => \@func_list,
	vars => \@var_list
    };
}

