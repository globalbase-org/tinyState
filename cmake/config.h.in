/* config.h.in */

/**
 * @file tinyState_config.h
 * @brief Build-time configuration header, generated by CMake from
 *        `cmake/config.h.in` into `<build>/tinyState_config.h` and installed
 *        to `<prefix>/include/std2/`. /
 *        CMake が `cmake/config.h.in` から生成するビルド構成ヘッダ。
 */

/**
 * @def TS_VERSION
 * @brief Semantic version string of the framework (e.g. `"2.0.0"`). /
 *        フレームワークの semver 文字列。
 * @details Single source of truth: `project(tinyState VERSION ...)` in the
 *          top-level `CMakeLists.txt`.  Distinct from @ref TS_REVISION, which
 *          is the exact git provenance. /
 *          単一ソースは `CMakeLists.txt` の `project(... VERSION ...)`。
 *          正確な出所を表す @ref TS_REVISION とは別物。
 */
#define TS_VERSION        "@tinyState_VERSION@"
/** @brief Major component of @ref TS_VERSION (integer). */
#define TS_VERSION_MAJOR  @tinyState_VERSION_MAJOR@
/** @brief Minor component of @ref TS_VERSION (integer). */
#define TS_VERSION_MINOR  @tinyState_VERSION_MINOR@
/** @brief Patch component of @ref TS_VERSION (integer). */
#define TS_VERSION_PATCH  @tinyState_VERSION_PATCH@
/**
 * @def TS_REVISION
 * @brief git provenance string, captured at CMake *configure* time. /
 *        CMake configure 時点で取得する git 由来リビジョン文字列。
 * @details `git describe --tags --always --dirty --long` — nearest tag,
 *          commits-since, short hash, and a `-dirty` suffix if the working
 *          tree has uncommitted changes (e.g. `v2.0.0-3-gabc1234`).  Degrades
 *          to `"unknown"` outside a git checkout (release tarball).  The
 *          snapshot is taken at configure, so commits made after
 *          `cmake -B build .` are not reflected until the next configure. /
 *          git 管理外では `"unknown"`。configure 時のスナップショットのため
 *          再 configure まで最新コミットは反映されない。
 */
#define TS_REVISION       "@TS_REVISION@"

/** @brief Defined if `struct sockaddr` has an `sa_len` member (BSD/macOS). */
#cmakedefine HAVE_SA_LEN

/** @brief Defined if POSIX signal handling is available. */
#cmakedefine HAVE_SIGNAL
/** @brief Defined if pthreads are available (always set; see CMakeLists.txt). */
#cmakedefine HAVE_PTHREAD

/** @brief Defined if CGAL was found and math2 geometry features are enabled. */
#cmakedefine HAVE_CGAL
